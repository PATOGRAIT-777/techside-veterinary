generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  cliente
  medico
  admin
}

enum UsuarioStatus {
  activo
  pendiente
  inactivo
}

model MxDivision {
  id           String   @id @default(uuid()) @db.Uuid
  codigoPostal String   @map("codigo_postal") @db.VarChar(10)
  colonia      String   @db.VarChar(255)
  municipio    String   @db.VarChar(255)
  estado       String   @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  personas     Persona[]
  sucursales   Sucursal[]

  @@index([codigoPostal])
  @@map("mx_divisiones")
}

model Persona {
  id                  String   @id @default(uuid()) @db.Uuid
  nombreCompleto      String   @map("nombre_completo") @db.VarChar(200)
  telefono            String   @db.VarChar(15)
  telefonoSecundario  String?  @map("telefono_secundario") @db.VarChar(15)
  
  // Dirección
  calle               String   @db.VarChar(200)
  numExterior         String?  @map("num_exterior") @db.VarChar(20)
  numInterior         String?  @map("num_interior") @db.VarChar(20)
  
  // NUEVO: Relación a la dirección usando el catálogo SEPOMEX
  ubicacionId         String?  @map("ubicacion_id") @db.Uuid
  ubicacion           MxDivision? @relation(fields: [ubicacionId], references: [id])

  // NUEVO: Documentos extra que venían en el SQL
  tipoIdentificacion  String?  @map("tipo_identificacion") @db.VarChar(50)
  numeroIdentificacion String? @map("numero_identificacion") @db.VarChar(100)
  proofAddressId      String?  @map("proof_address_id") @db.Uuid
  proofIdId           String?  @map("proof_id_id") @db.Uuid

  sucursalId          String   @map("sucursal_id") @db.Uuid
  sucursal            Sucursal @relation(fields: [sucursalId], references: [id])

  // NUEVO: Contactos de emergencia
  contactosEmergencia ContactoUsuario[]

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  usuario             Usuario?

  @@index([telefono])
  @@index([sucursalId])
  @@index([ubicacionId])
  @@map("persona")
}

model ContactoUsuario {
  id         String   @id @default(uuid()) @db.Uuid
  personaId  String   @map("persona_id") @db.Uuid
  persona    Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  nombre     String   @db.VarChar(200)
  relacion   String   @db.VarChar(100)
  telefono   String   @db.VarChar(15)
  creadoEn   DateTime @default(now()) @map("creado_en")

  @@index([personaId])
  @@map("contactos_usuarios")
}

model Usuario {
  id            String           @id @default(uuid()) @db.Uuid
  email         String           @unique @db.VarChar(255)
  telefono      String           @unique @db.VarChar(15)
  passwordHash  String           @map("password_hash") @db.Text
  rol           Rol
  status        UsuarioStatus    @default(pendiente)
  personaId     String           @unique @map("persona_id") @db.Uuid
  persona       Persona          @relation(fields: [personaId], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  emailVerifications  EmailVerificationToken[]
  passwordResets      PasswordResetToken[]
  mascotas            Mascota[]
  medico              Medico?

  ordenes             Orden[]

  @@index([email])
  @@index([telefono])
  @@index([rol])
  @@map("usuario")
}

model Archivo {
  id            String   @id @default(uuid()) @db.Uuid
  url           String   @db.Text
  nombreArchivo String   @map("nombre_archivo") @db.VarChar(255)
  mime          String   @db.VarChar(100)
  tamano        Int
  subidoEn      DateTime @default(now()) @map("subido_en")
  mascotasFotoPerfil Mascota[] @relation("MascotaFotoPerfil")
  mascotasCarnetVacunacion Mascota[] @relation("MascotaCarnetVacunacion")
  @@map("archivos")
}

model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  usuarioId String   @map("usuario_id") @db.Uuid
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  @@index([token])
  @@index([usuarioId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  usuarioId String   @map("usuario_id") @db.Uuid
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  @@index([token])
  @@index([usuarioId])
  @@map("password_reset_tokens")
}

model Especie {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  razas     Raza[]
  @@map("especies")
}

model Raza {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @db.VarChar(120)
  especieId String   @map("especie_id") @db.Uuid
  especie   Especie  @relation(fields: [especieId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  mascotas  Mascota[]
  @@unique([especieId, nombre])
  @@map("razas")
}

model Color {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  mascotas  Mascota[]
  @@map("colores")
}

model TipoPelo {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  mascotas  Mascota[]
  @@map("tipos_pelo")
}

model PatronPelo {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  mascotas  Mascota[]
  @@map("patrones_pelo")
}

model Comportamiento {
  id            String   @id @default(uuid()) @db.Uuid
  nombre        String   @unique @db.VarChar(120)
  requiereBozal Boolean  @default(false) @map("requiere_bozal")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  mascotas      Mascota[]
  @@map("comportamientos")
}

model CatalogoAlergia {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  mascotas  MascotaAlergia[]
  @@map("catalogo_alergias")
}

model Mascota {
  id                String   @id @default(uuid()) @db.Uuid
  propietarioId     String   @map("propietario_id") @db.Uuid
  propietario       Usuario  @relation(fields: [propietarioId], references: [id])
  nombre            String   @db.VarChar(100)
  razaId            String?  @map("raza_id") @db.Uuid
  raza              Raza?    @relation(fields: [razaId], references: [id])
  colorId           String?  @map("color_id") @db.Uuid
  color             Color?   @relation(fields: [colorId], references: [id])
  tipoPeloId        String?  @map("tipo_pelo_id") @db.Uuid
  tipoPelo          TipoPelo? @relation(fields: [tipoPeloId], references: [id])
  patronPeloId      String?  @map("patron_pelo_id") @db.Uuid
  patronPelo        PatronPelo? @relation(fields: [patronPeloId], references: [id])
  comportamientoId  String?  @map("comportamiento_id") @db.Uuid
  comportamiento    Comportamiento? @relation(fields: [comportamientoId], references: [id])
  fechaNacimiento   DateTime? @map("fecha_nacimiento")
  sexo              String?  @db.VarChar(20)
  peso              Decimal? @db.Decimal(10, 3)
  esterilizado      Boolean  @default(false)
  ruac              String?  @db.VarChar(50)
  microchip         String?  @db.VarChar(100)
  tatuaje           String?  @db.VarChar(100)
  fotoPerfilId      String?  @map("foto_perfil_id") @db.Uuid
  fotoPerfil        Archivo? @relation("MascotaFotoPerfil", fields: [fotoPerfilId], references: [id])
  carnetVacunacionId String? @map("carnet_vacunacion_id") @db.Uuid
  carnetVacunacion  Archivo? @relation("MascotaCarnetVacunacion", fields: [carnetVacunacionId], references: [id])
  observaciones     String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  alergias          MascotaAlergia[]
  citas             Cita[]
  @@map("mascotas")
}

model MascotaAlergia {
  mascotaId   String          @map("mascota_id") @db.Uuid
  alergiaId   String          @map("alergia_id") @db.Uuid
  notas       String?         @db.VarChar(500)
  mascota     Mascota         @relation(fields: [mascotaId], references: [id], onDelete: Cascade)
  alergia     CatalogoAlergia @relation(fields: [alergiaId], references: [id], onDelete: Cascade)
  @@id([mascotaId, alergiaId])
  @@map("mascota_alergias")
}

// ============================================================
// Dominio Médico — Citas, Médicos, Recetas y Consultas
// ============================================================

enum EstadoPago {
  pendiente
  pagada
  cancelada
}

enum EstadoCita {
  pendiente_de_pago
  pendiente
  en_curso
  inasistencia
  completada
  cancelada
}

enum EstadoAsistencia {
  asistencia
  falta
  retardo
  justificado
  incapacidad
}

enum DiaSemana {
  domingo
  lunes
  martes
  miercoles
  jueves
  viernes
  sabado
}

model Sucursal {
  id                String   @id @default(uuid()) @db.Uuid
  nombre            String   @db.VarChar(120)
  calleNumero       String?  @map("calle_numero") @db.VarChar(255)
  ubicacionId       String?  @map("ubicacion_id") @db.Uuid
  mapaCoords        String?  @map("mapa_coords") @db.VarChar(100)
  descripcionWeb    String?  @map("descripcion_web") @db.Text
  horarioAtencion   String?  @map("horario_atencion") @db.VarChar(255)
  fotoPortadaId     String?  @map("foto_portada_id") @db.Uuid
  telefonoPrincipal String?  @map("telefono_principal") @db.VarChar(20)
  whatsapp          String?  @db.VarChar(20)
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")

  ubicacion         MxDivision? @relation(fields: [ubicacionId], references: [id])
  personas          Persona[]
  consultorios      Consultorio[]
  medicos           Medico[]
  especialidades    SucursalEspecialidad[]
  citas             Cita[]

  inventarios       InventarioSucursal[]
  ordenes           Orden[]

  @@index([ubicacionId])
  @@index([activo])
  @@map("sucursales")
}

model Consultorio {
  id           String   @id @default(uuid()) @db.Uuid
  sucursalId   String   @map("sucursal_id") @db.Uuid
  nombre       String   @db.VarChar(100)
  equipamiento String?  @db.Text

  sucursal       Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  medicoHorarios MedicoHorario[]

  @@index([sucursalId])
  @@map("consultorios")
}

model Especialidad {
  id          String   @id @default(uuid()) @db.Uuid
  nombre      String   @unique @db.VarChar(120)
  descripcion String?  @db.Text
  precio      Decimal  @default(0) @db.Decimal(10, 2)

  medicos          Medico[]
  sucursales       SucursalEspecialidad[]

  @@map("especialidades")
}

model Servicio {
  id         String   @id @default(uuid()) @db.Uuid
  nombre     String   @unique @db.VarChar(120)
  precioBase Decimal  @default(0) @map("precio_base") @db.Decimal(10, 2)

  citas      Cita[]

  @@map("servicios")
}

model SucursalEspecialidad {
  sucursalId     String @map("sucursal_id") @db.Uuid
  especialidadId String @map("especialidad_id") @db.Uuid

  sucursal       Sucursal     @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  especialidad   Especialidad @relation(fields: [especialidadId], references: [id], onDelete: Cascade)

  @@id([sucursalId, especialidadId])
  @@index([especialidadId])
  @@map("sucursales_especialidades")
}

model Medico {
  id                      String   @id @default(uuid()) @db.Uuid
  usuarioId               String   @unique @map("usuario_id") @db.Uuid
  sucursalId              String?  @map("sucursal_id") @db.Uuid
  especialidadPrincipalId String?  @map("especialidad_principal_id") @db.Uuid
  cedulaProfesional       String?  @map("cedula_profesional") @db.VarChar(50)
  biografiaCorta          String?  @map("biografia_corta") @db.Text

  usuario                 Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  sucursal                Sucursal?    @relation(fields: [sucursalId], references: [id])
  especialidadPrincipal   Especialidad? @relation(fields: [especialidadPrincipalId], references: [id])

  horarios                MedicoHorario[]
  asistencias             MedicoAsistencia[]
  citas                   Cita[]
  recetas                 Receta[]

  @@index([sucursalId])
  @@index([especialidadPrincipalId])
  @@map("medicos")
}

model MedicoHorario {
  id            String    @id @default(uuid()) @db.Uuid
  medicoId      String    @map("medico_id") @db.Uuid
  diaSemana     DiaSemana
  horaInicio    DateTime  @map("hora_inicio") @db.Time
  horaFin       DateTime  @map("hora_fin") @db.Time
  consultorioId String    @map("consultorio_id") @db.Uuid

  medico        Medico      @relation(fields: [medicoId], references: [id], onDelete: Cascade)
  consultorio   Consultorio @relation(fields: [consultorioId], references: [id])

  @@unique([medicoId, diaSemana, horaInicio])
  @@index([medicoId])
  @@index([consultorioId])
  @@map("medico_horarios")
}

model MedicoAsistencia {
  id                String            @id @default(uuid()) @db.Uuid
  medicoId          String            @map("medico_id") @db.Uuid
  fecha             DateTime          @db.Date
  horaEntradaReal   DateTime?         @map("hora_entrada_real") @db.Time
  horaSalidaReal    DateTime?         @map("hora_salida_real") @db.Time
  estado            EstadoAsistencia
  observaciones     String?           @db.Text
  creadoEn          DateTime          @default(now()) @map("creado_en")

  medico            Medico            @relation(fields: [medicoId], references: [id], onDelete: Cascade)

  @@unique([medicoId, fecha])
  @@index([medicoId])
  @@index([fecha])
  @@map("medico_asistencias")
}

model Cita {
  id             String     @id @default(uuid()) @db.Uuid
  sucursalId     String     @map("sucursal_id") @db.Uuid
  medicoId       String     @map("medico_id") @db.Uuid
  mascotaId      String     @map("mascota_id") @db.Uuid
  servicioId     String     @map("servicio_id") @db.Uuid
  fecha          DateTime   @db.Date
  horaInicio     DateTime   @map("hora_inicio") @db.Time
  horaFin        DateTime   @map("hora_fin") @db.Time
  estado         EstadoCita @default(pendiente_de_pago)
  motivo         String?    @db.Text
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  sucursal       Sucursal   @relation(fields: [sucursalId], references: [id])
  medico         Medico     @relation(fields: [medicoId], references: [id])
  mascota        Mascota    @relation(fields: [mascotaId], references: [id])
  servicio       Servicio   @relation(fields: [servicioId], references: [id])
  receta         Receta?
  consulta       Consulta?
  pago           Pago?
  historial      CitaEstadoHistorial[]

  @@index([sucursalId])
  @@index([medicoId])
  @@index([mascotaId])
  @@index([servicioId])
  @@index([fecha])
  @@index([estado])
  @@index([medicoId, fecha, estado])
  @@index([mascotaId, fecha, estado])
  @@map("citas")
}

model Receta {
  id            String   @id @default(uuid()) @db.Uuid
  citaId        String   @unique @map("cita_id") @db.Uuid
  diagnostico   String   @db.Text
  observaciones String?  @db.Text
  fechaReceta   DateTime @default(now()) @map("fecha_receta")

  medicoId      String   @map("medico_id") @db.Uuid
  medico        Medico   @relation(fields: [medicoId], references: [id])
  cita          Cita     @relation(fields: [citaId], references: [id], onDelete: Cascade)
  detalles      DetalleReceta[]

  @@index([medicoId])
  @@map("recetas")
}

model DetalleReceta {
  id                String  @id @default(uuid()) @db.Uuid
  recetaId          String  @map("receta_id") @db.Uuid
  medicamento       String  @db.VarChar(500)
  dosis             String  @db.VarChar(255)
  frecuencia        String  @db.VarChar(255)
  duracion          String  @db.VarChar(255)
  viaAdministracion String  @map("via_administracion") @db.VarChar(255)
  instrucciones     String? @db.Text

  receta            Receta  @relation(fields: [recetaId], references: [id], onDelete: Cascade)

  @@index([recetaId])
  @@map("detalles_receta")
}

model Pago {
  id         String     @id @default(uuid()) @db.Uuid
  citaId     String     @unique @map("cita_id") @db.Uuid
  folioPago  String     @unique @map("folio_pago") @db.VarChar(20)
  cantidad   Decimal    @db.Decimal(10, 2)
  estado     EstadoPago @default(pendiente)
  fechaPago  DateTime?  @map("fecha_pago")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  cita       Cita       @relation(fields: [citaId], references: [id], onDelete: Cascade)

  @@index([folioPago])
  @@index([estado])
  @@map("pagos")
}

model Consulta {
  id                     String  @id @default(uuid()) @db.Uuid
  citaId                 String  @unique @map("cita_id") @db.Uuid
  peso                   Decimal? @db.Decimal(10, 3)
  temperatura            Decimal? @db.Decimal(5, 2)
  frecuenciaCardiaca     Int?    @map("frecuencia_cardiaca")
  frecuenciaRespiratoria Int?    @map("frecuencia_respiratoria")
  presionArterial        String? @map("presion_arterial") @db.VarChar(20)
  estadoGeneral          String? @map("estado_general") @db.VarChar(500)
  notasEvolucion         String? @map("notas_evolucion") @db.Text

  cita                   Cita    @relation(fields: [citaId], references: [id], onDelete: Cascade)

  @@map("consultas")
}

model CitaEstadoHistorial {
  id             String    @id @default(uuid()) @db.Uuid
  citaId         String    @map("cita_id") @db.Uuid
  estadoAnterior String?   @map("estado_anterior") @db.VarChar(30)
  estadoNuevo    String    @map("estado_nuevo") @db.VarChar(30)
  usuarioId      String?   @map("usuario_id") @db.Uuid
  razon          String?   @db.Text
  fechaCambio    DateTime  @default(now()) @map("fecha_cambio")

  cita           Cita      @relation(fields: [citaId], references: [id], onDelete: Cascade)

  @@index([citaId])
  @@index([fechaCambio])
  @@map("cita_estado_historial")
}

// ============================================================
// Dominio de Tienda e Inventario (E-Commerce)
// ============================================================

model CategoriaProducto {
  id          String     @id @default(uuid()) @db.Uuid
  nombre      String     @unique @db.VarChar(120)
  descripcion String?    @db.Text
  productos   Producto[]

  @@map("categorias_producto")
}

model Producto {
  id              String   @id @default(uuid()) @db.Uuid
  codigoSku       String?  @unique @map("codigo_sku") @db.VarChar(100)
  nombre          String   @db.VarChar(200)
  descripcion     String?  @db.Text
  precioVenta     Decimal  @map("precio_venta") @db.Decimal(10, 2)
  costoCompra     Decimal? @map("costo_compra") @db.Decimal(10, 2)

  categoriaId     String?  @map("categoria_id") @db.Uuid
  categoria       CategoriaProducto? @relation(fields: [categoriaId], references: [id])

  esMedicamento   Boolean  @default(false) @map("es_medicamento")
  requiereReceta  Boolean  @default(false) @map("requiere_receta")

  imagenUrl       String?  @map("imagen_url") @db.Text
  marca           String?  @db.VarChar(100)
  activo          Boolean  @default(true)

  inventarios     InventarioSucursal[]
  detallesOrden   DetalleOrden[]

  @@map("productos")
}

model InventarioSucursal {
  id                 String   @id @default(uuid()) @db.Uuid
  sucursalId         String   @map("sucursal_id") @db.Uuid
  productoId         String   @map("producto_id") @db.Uuid

  cantidadExistencia Int      @default(0) @map("cantidad_existencia")
  stockMinimo        Int      @default(5) @map("stock_minimo")
  ubicacionEnAlmacen String?  @map("ubicacion_en_almacen") @db.VarChar(255)

  fechaActualizacion DateTime @default(now()) @updatedAt @map("fecha_actualizacion")

  sucursal           Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  producto           Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([sucursalId, productoId])
  @@map("inventario_sucursal")
}

enum EstadoOrden {
  pendiente_pago
  pagado
  en_preparacion
  enviado
  entregado
  cancelado
  devolucion
}

model Orden {
  id             String         @id @default(uuid()) @db.Uuid
  usuarioId      String         @map("usuario_id") @db.Uuid
  sucursalId     String         @map("sucursal_id") @db.Uuid // Desde qué sucursal se surte

  fechaCompra    DateTime       @default(now()) @map("fecha_compra")
  total          Decimal        @db.Decimal(10, 2)
  estado         EstadoOrden    @default(pendiente_pago)
  metodoPago     String?        @map("metodo_pago") @db.VarChar(50)
  direccionEnvio String         @map("direccion_envio") @db.Text

  usuario        Usuario        @relation(fields: [usuarioId], references: [id])
  sucursal       Sucursal       @relation(fields: [sucursalId], references: [id])
  detalles       DetalleOrden[]

  @@index([usuarioId])
  @@index([sucursalId])
  @@map("ordenes")
}

model DetalleOrden {
  id             String   @id @default(uuid()) @db.Uuid
  ordenId        String   @map("orden_id") @db.Uuid
  productoId     String   @map("producto_id") @db.Uuid

  cantidad       Int
  precioUnitario Decimal  @map("precio_unitario") @db.Decimal(10, 2)

  orden          Orden    @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  producto       Producto @relation(fields: [productoId], references: [id])

  @@index([ordenId])
  @@index([productoId])
  @@map("detalles_orden")
}